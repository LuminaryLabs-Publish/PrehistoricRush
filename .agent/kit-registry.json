      "recommendedFix": "Load runner-tuning.json into runtime services and keep inline constants only as fallback defaults."
    },
    {
      "id": "monolithic-runtime-ownership",
      "detail": "src/runtime-terrain-v6.mjs owns too many reusable domains.",
