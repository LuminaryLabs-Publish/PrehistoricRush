  "knownBlockers": [
    { "id": "runtime-tuning-duplication", "detail": "runner-tuning.json defines product tuning, but runtime-terrain-v6.mjs still owns inline speed, terrain, spawn, and win constants." },
    { "id": "runtime-manifest-drift", "detail": "runtime values currently differ from runner-tuning.json for motion speed, max speed, boost speed, turn rate, terrain chunk size, terrain segments, and seed shape." },
    { "id": "scene-result-name-mismatch", "detail": "game-scenes.json routes game:runOver to run-over, while scenes/game.json still says nextOnLoss: fail." },
    { "id": "scene-dispatch-gap", "detail": "Runtime mutates app.scene directly instead of returning explicit accepted/rejected SceneDispatchResult records." },
    { "id": "runner-step-result-gap", "detail": "Runner movement mutates x, y, z, jumpY, speed, yaw, distance, grounded, and best without a RunnerStepResult." },
    { "id": "contact-result-gap", "detail": "Hazard, pickup, and win checks mutate state directly without ContactEvent or ContactResult records." },
    { "id": "space-key-semantic-overlap", "detail": "Space starts outside active gameplay and jumps inside gameplay; this must be routed through scene-scoped ActionFrame records." },
    { "id": "action-frame-validity-gap", "detail": "Input is live boolean state with no accepted/rejected action-frame contract." },
